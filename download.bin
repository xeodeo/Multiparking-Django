/*!50003 CREATE*/ /*!50017 DEFINER=`root`@`localhost`*/ /*!50003 TRIGGER trg_parqueos_ai_ins_ocupar
AFTER INSERT ON parqueos
FOR EACH ROW
BEGIN
  IF NEW.fkIdEspacio IS NOT NULL THEN
    UPDATE espacios SET espEstado='OCUPADO'
    WHERE idEspacio=NEW.fkIdEspacio;
  END IF;
END */;;
DELIMITER ;
