/*!50003 CREATE*/ /*!50017 DEFINER=`root`@`localhost`*/ /*!50003 TRIGGER trg_reservas_bi_ins_validar
BEFORE INSERT ON reservas
FOR EACH ROW
BEGIN
  IF NEW.resHoraInicio >= NEW.resHoraFin THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT='HoraInicio debe ser menor que HoraFin';
  END IF;
  SET NEW.resFechaReserva = DATE(NEW.resHoraInicio);
  IF NEW.resEstado IS NULL THEN
    SET NEW.resEstado = 'RESERVADO';
  END IF;
END */;;
DELIMITER ;
