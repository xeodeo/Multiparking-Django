DELIMITER ;;
/*!50003 CREATE*/ /*!50017 DEFINER=`root`@`localhost`*/ /*!50003 TRIGGER trg_parqueos_au_upd_liberar
AFTER UPDATE ON parqueos
FOR EACH ROW
BEGIN
  IF OLD.parHoraSalida IS NULL AND NEW.parHoraSalida IS NOT NULL
     AND NEW.fkIdEspacio IS NOT NULL THEN
    IF NOT EXISTS (
      SELECT 1 FROM parqueos p
      WHERE p.fkIdEspacio=NEW.fkIdEspacio
        AND p.parHoraSalida IS NULL
    ) THEN
      UPDATE espacios SET espEstado='DISPONIBLE'
      WHERE idEspacio=NEW.fkIdEspacio;
    END IF;
  END IF;
END */;;
DELIMITER ;
